from sklearn import tree


features=[[150,0],
[170,0],
[130,1],
[120,1]]


labels=["apple","apple","orange","orange"]


clf=tree.DecisionTreeClassifier()


clf=clf.fit(features,labels)



prediction=clf.predict([[150,1]])


print(f"The fruit is {prediction[0]}")


